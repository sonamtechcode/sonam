# ============================================
# RENDER DEPLOYMENT CONFIGURATION
# ============================================

# Server Configuration
PORT=5000
NODE_ENV=production

# ============================================
# DATABASE CONFIGURATION (PostgreSQL)
# ============================================
# For local development:
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your_password
DB_NAME=hospital_management

# For Render + Supabase PostgreSQL:
# 1. Create PostgreSQL database on Supabase
# 2. Get connection details from Supabase dashboard
# 3. Set these variables:
# DB_HOST=your_supabase_host.supabase.co
# DB_PORT=5432
# DB_USER=postgres
# DB_PASSWORD=your_supabase_password
# DB_NAME=postgres

# ============================================
# JWT Configuration
# ============================================
JWT_SECRET=your_jwt_secret_key_here_minimum_32_characters_long
JWT_EXPIRE=7d

# ============================================
# Email Configuration (Gmail)
# ============================================
EMAIL_USER=solvixo.co@gmail.com
EMAIL_PASSWORD=your_gmail_app_password

# ============================================
# Frontend Configuration
# ============================================
FRONTEND_URL=https://healthhub-gamma.vercel.app

# ============================================
# Optional Services
# ============================================
ENABLE_WHATSAPP=false

# ============================================
# RENDER DEPLOYMENT NOTES
# ============================================
# 1. Render will automatically set PORT
# 2. Set NODE_ENV=production for production
# 3. All DB_* variables are REQUIRED
# 4. Server will start even if DB connection fails
# 5. Health check: GET /health
